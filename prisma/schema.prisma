generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  clerkId      String   @unique
  email        String   @unique
  name         String
  role         Role     @default(EMPLOYEE)
  department   String?
  designation  String?
  managerId    String?
  manager      User?    @relation("ManagerEmployee", fields: [managerId], references: [id])
  employees    User[]   @relation("ManagerEmployee")
  goals        Goal[]
  checkIns     CheckIn[]
  auditLogs    AuditLog[]
  notifications Notification[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

model Cycle {
  id        String   @id @default(cuid())
  name      String
  year      Int
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  goals     Goal[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cycles")
}

model Goal {
  id             String     @id @default(cuid())
  userId         String
  cycleId        String
  thrustArea     String
  title          String
  description    String?
  uom            UoM
  target         Float
  weightage      Float
  deadline       DateTime
  status         GoalStatus @default(DRAFT)
  isShared       Boolean    @default(false)
  isLowerBetter  Boolean    @default(false)
  parentGoalId   String?
  managerComment String?
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle          Cycle      @relation(fields: [cycleId], references: [id])
  parentGoal     Goal?      @relation("SharedGoal", fields: [parentGoalId], references: [id])
  childGoals     Goal[]     @relation("SharedGoal")
  checkIns       CheckIn[]
  auditLogs      AuditLog[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("goals")
}

enum UoM {
  NUMERIC
  PERCENTAGE
  TIMELINE
  ZERO_BASED
}

enum GoalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REWORK
  LOCKED
}

model CheckIn {
  id              String        @id @default(cuid())
  goalId          String
  userId          String
  quarter         Quarter
  achievement     Float?
  completionDate  DateTime?
  status          CheckInStatus @default(NOT_STARTED)
  managerComment  String?
  progressScore   Float?
  goal            Goal          @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([goalId, quarter])
  @@map("check_ins")
}

enum Quarter {
  Q1
  Q2
  Q3
  Q4
}

enum CheckInStatus {
  NOT_STARTED
  ON_TRACK
  COMPLETED
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  goalId    String?
  action    String
  entity    String   @default("goal")
  prevValue Json?
  newValue  Json?
  metadata  Json?
  user      User     @relation(fields: [userId], references: [id])
  goal      Goal?    @relation(fields: [goalId], references: [id])
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  link      String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("notifications")
}
